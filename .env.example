# VectorAI DB connection
VECTORAI_HOST=localhost
VECTORAI_PORT=50051

# Footage directory (mount your camera footage here)
FOOTAGE_DIR=./footage

# Data directory (thumbnails + cache)
DATA_DIR=./data

# Indexing settings
FRAME_RATE=1           # frames per second to sample (1 = 1 fps)
MOTION_THRESHOLD=25    # pixel difference threshold for motion detection (0-255)
